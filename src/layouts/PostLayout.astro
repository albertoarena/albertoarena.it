---
import Layout from "../components/Layout.astro";
import type { CollectionEntry } from "astro:content";
import { siteConfig } from "../utils/config";
import DisqusComments from "../components/DisqusComments.astro";
import LanguageToggle from "../components/LanguageToggle.astro";

interface Props {
    post: CollectionEntry<"posts">;
    lang?: 'en' | 'it';
    englishUrl?: string;
    italianUrl?: string;
    disqusSlug?: string;
}

const { post, lang = 'en', englishUrl, italianUrl, disqusSlug } = Astro.props;

const locale = lang === 'it' ? 'it-IT' : 'en-US';
const formattedDate = post.data.date.toLocaleDateString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});

const categorySlug = post.data.category?.toLowerCase().replace(/\s+/g, '-');

// Disqus always uses the English post's slug and URL so both languages share one thread
const canonicalEnglishSlug = disqusSlug ?? post.slug;
const disqusPostUrl = `${siteConfig.url}/posts/${canonicalEnglishSlug}/`;

const hasTranslation = !!(englishUrl && italianUrl);
const hreflangEn = englishUrl ? `${siteConfig.url}${englishUrl}` : undefined;
const hreflangIt = italianUrl ? `${siteConfig.url}${italianUrl}` : undefined;
---

<Layout
    title={post.data.title}
    description={post.data.description}
    image={post.data.socialImage}
    article={true}
    lang={lang}
    hreflangEn={hreflangEn}
    hreflangIt={hreflangIt}
>
    <article class="prose dark:prose-invert max-w-none">
        <header class="mb-8 not-prose">
            {hasTranslation && (
                <LanguageToggle
                    currentLang={lang}
                    englishUrl={englishUrl!}
                    italianUrl={italianUrl!}
                />
            )}
            <h1 class="text-3xl lg:text-4xl font-bold mb-4 text-dark dark:text-white">{post.data.title}</h1>
            <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-300">
                <time datetime={post.data.date.toISOString()} class="text-gray-600 dark:text-gray-200 no-underline" style="text-decoration: none !important;">
                    {formattedDate}
                </time>
                {post.data.category && (
                    <a
                        href={`/category/${categorySlug}`}
                        class="px-2 py-1 bg-primary/10 dark:bg-dark-cloud text-primary dark:text-gray-200 rounded font-medium hover:bg-primary/20 transition-colors"
                    >
                        {post.data.category}
                    </a>
                )}
            </div>
        </header>

        <slot />

        {post.data.tags && post.data.tags.length > 0 && (
            <footer class="mt-12 pt-6 border-t border-gray-200 dark:border-dark-cloud not-prose">
                <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                        <a
                            href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                            class="px-3 py-1 bg-gray-100 dark:bg-dark-cloud text-gray-700 dark:text-gray-200 rounded-full text-sm hover:bg-secondary hover:text-white transition-colors"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            </footer>
        )}

        <div class="mt-12 pt-6 border-t border-gray-200 dark:border-dark-cloud not-prose">
            <div class="flex items-center gap-4">
                <img
                    src={siteConfig.author.photo}
                    alt={siteConfig.author.name}
                    class="w-16 h-16 rounded-full"
                />
                <div>
                    <p class="font-semibold text-dark dark:text-white">{siteConfig.author.name}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-300">{siteConfig.author.bio}</p>
                </div>
            </div>
        </div>

        <DisqusComments
            url={disqusPostUrl}
            identifier={canonicalEnglishSlug}
            title={post.data.title}
        />
    </article>
</Layout>
