---
import Layout from "../components/Layout.astro";
import type { CollectionEntry } from "astro:content";
import { siteConfig } from "../utils/config";
import DisqusComments from "../components/DisqusComments.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
import readingTime from "reading-time";

interface Props {
    post: CollectionEntry<"posts">;
    slug: string;
    lang?: 'en' | 'it';
    englishUrl?: string;
    italianUrl?: string;
    disqusSlug?: string;
}

const { post, slug, lang = 'en', englishUrl, italianUrl, disqusSlug } = Astro.props;

const locale = lang === 'it' ? 'it-IT' : 'en-US';
const formattedDate = post.data.date.toLocaleDateString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});

const categorySlug = post.data.category?.toLowerCase().replace(/\s+/g, '-');
const readTime = readingTime(post.body).text;

const canonicalEnglishSlug = disqusSlug ?? slug;
const disqusPostUrl = `${siteConfig.url}/posts/${canonicalEnglishSlug}/`;

const hasTranslation = !!(englishUrl && italianUrl);
const hreflangEn = englishUrl ? `${siteConfig.url}${englishUrl}` : undefined;
const hreflangIt = italianUrl ? `${siteConfig.url}${italianUrl}` : undefined;
---

<Layout
    title={post.data.title}
    description={post.data.description}
    image={post.data.socialImage}
    article={true}
    lang={lang}
    hreflangEn={hreflangEn}
    hreflangIt={hreflangIt}
>
    <article>
        <!-- Full-width post header -->
        <header class="mb-10">
            {hasTranslation && (
                <LanguageToggle
                    currentLang={lang}
                    englishUrl={englishUrl!}
                    italianUrl={italianUrl!}
                />
            )}
            <h1 class="text-4xl font-bold leading-tight mb-4 text-dark dark:text-white">{post.data.title}</h1>
            <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-gray">
                <time datetime={post.data.date.toISOString()} class="no-underline">
                    {formattedDate}
                </time>
                {post.data.category && (
                    <a
                        href={`/category/${categorySlug}/`}
                        class="px-2 py-1 bg-primary/10 dark:bg-dark-cloud text-primary dark:text-white-cloud rounded font-medium hover:bg-primary/20 transition-colors"
                    >
                        {post.data.category}
                    </a>
                )}
                <span>{readTime}</span>
            </div>
        </header>

        <!-- Prose body at reading measure -->
        <div class="prose dark:prose-invert max-w-[68ch]">
            <slot />
        </div>

        <!-- Full-width post footer -->
        {post.data.tags && post.data.tags.length > 0 && (
            <footer class="mt-12 pt-6 border-t border-white-cloud dark:border-dark-cloud">
                <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                        <a
                            href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
                            class="px-3 py-1 bg-gray-100 dark:bg-dark-cloud text-gray-700 dark:text-white-cloud rounded-full text-sm hover:bg-secondary hover:text-white transition-colors"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            </footer>
        )}

        <div class="mt-12 pt-6 border-t border-white-cloud dark:border-dark-cloud">
            <div class="flex items-center gap-4">
                <img
                    src={siteConfig.author.photo}
                    alt={siteConfig.author.name}
                    class="w-14 h-14 rounded-full"
                />
                <div>
                    <p class="font-semibold text-dark dark:text-white">{siteConfig.author.name}</p>
                    <p class="text-sm text-gray">{siteConfig.author.bio}</p>
                </div>
            </div>
        </div>

        <DisqusComments
            url={disqusPostUrl}
            identifier={canonicalEnglishSlug}
            title={post.data.title}
        />
    </article>
</Layout>
