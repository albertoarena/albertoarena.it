---
import { siteConfig } from '@/utils/config';

const { accountId, formId } = siteConfig.mailerlite;
---

<div data-form={formId} class="ml-embedded"></div>

<script is:inline define:vars={{ accountId }}>
  function initMailerLite() {
    window.ml = window.ml || function() { (window.ml.q = window.ml.q || []).push(arguments); };
    if (!window._mlLoaded) {
      window._mlLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://assets.mailerlite.com/js/universal.js';
      document.head.appendChild(s);
    }
    ml('account', accountId);
  }

  // Handle both direct load and View Transitions navigation
  if (document.readyState === 'loading') {
    document.addEventListener('astro:page-load', initMailerLite, { once: true });
  } else {
    initMailerLite();
  }
</script>
