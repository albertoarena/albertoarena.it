---
import type { CollectionEntry } from "astro:content";
import readingTime from "reading-time";
import { getPostSlug } from "@/utils/helpers";

interface Props {
    post: CollectionEntry<"posts">;
    pinned?: boolean;
}

const { post, pinned = false } = Astro.props;
const categorySlug = post.data.category?.toLowerCase().replace(/\s+/g, "-");
const readTime = readingTime(post.body).text;
const postSlug = getPostSlug(post);

const thumbnail = pinned
    ? (post.data.cover
        ? (post.data.cover.startsWith("http") ? post.data.cover : `/images/posts/${post.data.cover}`)
        : post.data.socialImage)
    : undefined;
---

<article class={`group border-l-2 pl-5 transition-all duration-200 ${pinned ? "border-primary" : "border-transparent hover:border-l-primary"}`}>
    <div class="flex items-center gap-3 text-sm font-mono text-gray">
        <time datetime={post.data.date.toISOString()} class="whitespace-nowrap">
            {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
            })}
        </time>
        {post.data.category && (
            <>
                <span aria-hidden="true" class="opacity-40">/</span>
                <a
                    href={`/category/${categorySlug}/`}
                    class="hover:text-primary transition-colors"
                >
                    {post.data.category}
                </a>
            </>
        )}
        <span aria-hidden="true" class="opacity-40">/</span>
        <span>{readTime}</span>
    </div>

    <a href={`/posts/${postSlug}/`} class="mt-1 flex items-start gap-4 sm:gap-5">
        {thumbnail && (
            <img
                src={thumbnail}
                alt={post.data.title}
                class="shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-lg object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                loading="lazy"
            />
        )}

        <div class="min-w-0 space-y-1">
            <h2 class="text-xl font-semibold group-hover:text-primary transition-colors text-dark dark:text-white">
                {post.data.title}
            </h2>

            {post.data.description && (
                <p class="text-gray mt-1 line-clamp-2">
                    {post.data.description}
                </p>
            )}
        </div>
    </a>
</article>
