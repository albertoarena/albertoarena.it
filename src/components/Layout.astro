---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  lang?: 'en' | 'it';
  hreflangEn?: string;
  hreflangIt?: string;
}

const { title, description, image, article = false, lang = 'en', hreflangEn, hreflangIt } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  article={article}
  lang={lang}
  hreflangEn={hreflangEn}
  hreflangIt={hreflangIt}
>
  <Header />
  <main id="main-content" class="max-w-3xl mx-auto px-6 py-12 animate-fade-in">
    <slot />
  </main>
  <Footer />
  <CookieConsent />
</BaseLayout>
