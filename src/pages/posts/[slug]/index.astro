---
import { getCollection, render } from "astro:content";
import PostLayout from "../../../layouts/PostLayout.astro";
import { getPostSlug } from "@/utils/helpers";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts");
    const englishPosts = allPosts.filter((p) => (p.data.lang ?? 'en') === 'en');
    const translatedSlugs = new Set(
        allPosts
            .filter((p) => p.data.lang === 'it')
            .map((p) => p.data.translationOf)
            .filter(Boolean)
    );

    return englishPosts.map((post) => {
        const slug = getPostSlug(post);
        return {
            params: { slug },
            props: { post, hasItalian: translatedSlugs.has(slug) },
        };
    });
}

const { post, hasItalian } = Astro.props;
const { Content } = await render(post);

const slug = getPostSlug(post);
const englishPath = `/posts/${slug}/`;
const italianPath = `/posts/${slug}/it/`;
---

<PostLayout
    post={post}
    slug={slug}
    lang="en"
    englishUrl={hasItalian ? englishPath : undefined}
    italianUrl={hasItalian ? italianPath : undefined}
>
    <Content />
</PostLayout>
