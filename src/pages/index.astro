---
import Layout from "../components/Layout.astro";
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import Pagination from "../components/Pagination.astro";
import { siteConfig } from "../utils/config";

const posts = await getCollection("posts");
const sortedPosts = posts
	.filter((post) => !post.data.draft && (post.data.lang ?? 'en') === 'en')
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pinnedPosts = sortedPosts.filter((p) => p.data.pinned);
const regularPosts = sortedPosts.filter((p) => !p.data.pinned);

const { postsLimit } = siteConfig;
const totalPages = Math.ceil(regularPosts.length / postsLimit);
const pagePosts = regularPosts.slice(0, postsLimit);
---

<Layout title={siteConfig.title}>
	<section class="mb-12 pb-10 border-b border-white-cloud dark:border-dark-cloud">
		<p class="text-2xl font-semibold text-dark dark:text-white leading-snug">
			Senior software engineer.
		</p>
		<p class="mt-3 text-gray leading-relaxed">
			I build and maintain developer tooling for Laravel and event sourcing, including the <a href="https://github.com/albertoarena/laravel-event-sourcing-generator" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-secondary transition-colors">Laravel Event Sourcing Generator</a> (10k+ downloads).
		</p>
		<p class="mt-2 text-sm font-mono">
			<a href="/pages/consulting/" class="text-primary hover:text-secondary transition-colors">Open to freelance, consulting, and long-term remote collaborations.</a>
		</p>
	</section>

	{pinnedPosts.length > 0 && (
		<div class="mb-10">
			<p class="text-xs font-mono text-gray uppercase tracking-widest mb-5">★ Pinned</p>
			<div class="space-y-8">
				{pinnedPosts.map((post) => <PostCard post={post} pinned={true} />)}
			</div>
		</div>
		<hr class="border-white-cloud dark:border-dark-cloud mb-10" />
	)}

	<div class="space-y-8 animate-stagger">
		{pagePosts.map((post) => <PostCard post={post} />)}
	</div>

	<Pagination currentPage={1} totalPages={totalPages} />
</Layout>